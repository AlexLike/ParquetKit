#!/usr/bin/env bash
set -euo pipefail

YELLOW='\033[0;33m' GREEN='\033[0;32m' RED='\033[0;31m' NC='\033[0m'

fail() { echo -e "${RED}✗ $1${NC}"; exit 1; }
pass() { echo -e "${GREEN}✓ $1${NC}"; }

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

echo "Running pre-commit checks…"

# ── Swift formatting ──────────────────────────────────────────────────────
echo -e "\n${YELLOW}Swift format lint…${NC}"
swift format lint --recursive --strict \
  "$ROOT_DIR/Sources/ParquetKit" \
  "$ROOT_DIR/Sources/ParquetKitMacros" \
  "$ROOT_DIR/Tests" \
  "$ROOT_DIR/Package.swift" \
  || fail "Swift formatting errors. Run: swift format --recursive Sources/ParquetKit Sources/ParquetKitMacros Tests Package.swift"
pass "Swift format"

# ── Rust formatting ───────────────────────────────────────────────────────
echo -e "\n${YELLOW}Rust fmt check…${NC}"
(cd "$ROOT_DIR/Driver" && cargo fmt --all -- --check) \
  || fail "Rust formatting errors. Run: cd Driver && cargo fmt --all"
pass "Rust fmt"

# ── Binary target freshness ───────────────────────────────────────────────
echo -e "\n${YELLOW}Binary target freshness…${NC}"
PREV=$(python3 -c "
import re, sys
text = open('$ROOT_DIR/Package.swift').read()
m = re.search(r'download/(v[^/]+)/ParquetKitFFI\.xcframework\.zip', text)
print(m.group(1) if m else '')
")
if [ -z "$PREV" ]; then
  pass "Binary target (path: form — xcframework will be rebuilt on next release)"
else
  CHANGED=$(git -C "$ROOT_DIR" diff --name-only "${PREV}"..HEAD -- Driver/)
  if [ -n "$CHANGED" ]; then
    echo "$CHANGED"
    fail "Driver/ has changed since ${PREV}. Run: bash scripts/use-local-binary"
  fi
  pass "Binary target (unchanged since ${PREV})"
fi

echo -e "\n${GREEN}All pre-commit checks passed.${NC}"
