10.4. Distributing Source Code Form that is Incompatible With Secondary
Licenses. If You choose to distribute Source Code Form that is Incompatible With
Secondary Licenses under the terms of this version of the License, the notice
described in Exhibit B of this License must be attached.

Exhibit A - Source Code Form License Notice
-------------------------------------------

  This Source Code Form is subject to the terms of the Mozilla Public
  License, v. 2.0. If a copy of the MPL was not distributed with this
  file, You can obtain one at http://mozilla.org/MPL/2.0/.

Exhibit B - "Incompatible With Secondary Licenses" Notice
----------------------------------------------------------

  This Source Code Form is "Incompatible With Secondary Licenses", as
  defined by the Mozilla Public License, v. 2.0."""

# ── Render ───────────────────────────────────────────────────────────────────
SEP = "=" * 80
lines = []

def section(title):
    lines.extend([SEP, title, SEP, ""])

lines += [
    "THIRD-PARTY SOFTWARE NOTICES",
    "",
    "ParquetKit incorporates third-party software components listed below.",
    "Each component is subject to its own license terms.",
    "",
    "",
]

# Swift deps
section("Swift Package Dependencies")
lines += [
    "The following Swift packages are licensed under the Apache License, Version 2.0",
    "with the Swift Runtime Library Exception.",
    "",
]
for dep in swift_deps:
    lines.append(f"  {dep['name']} {dep['version']}")
    lines.append(f"    {dep['copyright']}")
    lines.append(f"    {dep['location']}")
lines += ["", "License text (Apache License, Version 2.0 + Swift Runtime Library Exception):", ""]
lines.append(swift_apache_text)
lines += ["", SWIFT_RUNTIME_EXCEPTION, "", ""]

# Apache-2.0 Rust crates
apache_crates = sorted([c for c in crates if c["chosen"] == "Apache-2.0"], key=lambda c: c["name"])
apache_text = next(
    (c["text"] for c in apache_crates if c["text"] and "Apache License" in c["text"]), ""
)
section(f"Rust Crates \u2014 Apache License, Version 2.0  ({len(apache_crates)} crates)")
for c in apache_crates:
    cr = extract_copyright(c["text"])
    line = f"  {c['name']} {c['version']}"
    if cr:
        line += f"\n    {cr}"
    if c["repo"]:
        line += f"\n    {c['repo']}"
    lines.append(line)
lines += ["", "License text (Apache License, Version 2.0):", "", apache_text, "", ""]

# MIT Rust crates
mit_crates = sorted([c for c in crates if c["chosen"] == "MIT"], key=lambda c: c["name"])
mit_text = next(
    (c["text"] for c in mit_crates if c["text"] and "Permission is hereby" in c["text"]), ""
)
section(f"Rust Crates \u2014 MIT License  ({len(mit_crates)} crates)")
for c in mit_crates:
    cr = extract_copyright(c["text"])
    line = f"  {c['name']} {c['version']}"
    if cr:
        line += f"\n    {cr}"
    if c["repo"]:
        line += f"\n    {c['repo']}"
    lines.append(line)
lines += ["", "License text (MIT License):", "", mit_text, "", ""]

# MPL-2.0 Rust crates
mpl_crates = sorted([c for c in crates if c["chosen"] == "MPL-2.0"], key=lambda c: c["name"])
section(f"Rust Crates \u2014 Mozilla Public License 2.0  ({len(mpl_crates)} crates)")
for c in mpl_crates:
    line = f"  {c['name']} {c['version']}"
    repo = c["repo"] or "https://github.com/mozilla/uniffi-rs"
    line += f"\n    {repo}"
    lines.append(line)
lines += ["", "License text (Mozilla Public License 2.0):", "", MPL2_TEXT, "", ""]

# BSD Rust crates
bsd_crates = sorted(
    [c for c in crates if c["chosen"] in ("BSD-3-Clause", "BSD-2-Clause")],
    key=lambda c: c["name"],
)
if bsd_crates:
    section(f"Rust Crates \u2014 BSD License  ({len(bsd_crates)} crates)")
    for c in bsd_crates:
        line = f"  {c['name']} {c['version']}  ({c['chosen']})"
        if c["text"]:
            cr = extract_copyright(c["text"])
            if cr:
                line += f"\n    {cr}"
        if c["repo"]:
            line += f"\n    {c['repo']}"
        lines.append(line)
        if c["text"]:
            lines += ["", "  License text:", ""]
            lines += ["  " + l for l in c["text"].split("\n")]
            lines.append("")
    lines.append("")

# CC0 Rust crates
cc0_crates = sorted([c for c in crates if c["chosen"] == "CC0-1.0"], key=lambda c: c["name"])
if cc0_crates:
    section(f"Rust Crates \u2014 Creative Commons Zero (CC0-1.0)  ({len(cc0_crates)} crates)")
    for c in cc0_crates:
        line = f"  {c['name']} {c['version']}"
        if c["repo"]:
            line += f"\n    {c['repo']}"
        lines.append(line)
    lines += [
        "",
        "These components are released under CC0-1.0 (public domain dedication).",
        "No attribution is legally required, but is acknowledged here for completeness.",
        "",
    ]

with open(out_path, "w") as f:
    f.write("\n".join(lines) + "\n")

print(f"Written {len(lines)} lines to {out_path}")
PYEOF

echo "Done: $NOTICES_FILE"
