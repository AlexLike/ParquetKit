#!/bin/bash
# Regenerates the NOTICES file from Cargo.lock and Package.resolved.
# Run this whenever dependencies change.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
DRIVER_DIR="$ROOT_DIR/Driver"
CHECKOUTS_DIR="$ROOT_DIR/.build/checkouts"
NOTICES_FILE="$ROOT_DIR/NOTICES"

# ── Preflight ────────────────────────────────────────────────────────────────
if ! command -v python3 &>/dev/null; then
  echo "error: python3 is required" >&2; exit 1
fi
if [ ! -f "$DRIVER_DIR/Cargo.lock" ]; then
  echo "error: $DRIVER_DIR/Cargo.lock not found" >&2; exit 1
fi
if [ ! -f "$ROOT_DIR/Package.resolved" ]; then
  echo "error: $ROOT_DIR/Package.resolved not found" >&2; exit 1
fi

# Ensure Swift checkouts exist so we can read the license files
if [ ! -d "$CHECKOUTS_DIR" ]; then
  echo "Resolving Swift packages..."
  (cd "$ROOT_DIR" && swift package resolve)
fi

echo "Generating NOTICES..."

python3 - "$DRIVER_DIR/Cargo.lock" "$ROOT_DIR/Package.resolved" "$CHECKOUTS_DIR" "$NOTICES_FILE" << 'PYEOF'
import json, os, re, sys

cargo_lock_path, pkg_resolved_path, checkouts_dir, out_path = sys.argv[1:]

# ── Cargo registry ───────────────────────────────────────────────────────────
import glob as _glob
reg_candidates = _glob.glob(os.path.expanduser("~/.cargo/registry/src/index.crates.io-*"))
if not reg_candidates:
    print("error: ~/.cargo/registry not found — run 'cargo fetch' in Driver/ first", file=sys.stderr)
    sys.exit(1)
REG = reg_candidates[0]

# ── Parse Cargo.lock ─────────────────────────────────────────────────────────
with open(cargo_lock_path) as f:
    lock_content = f.read()

rust_packages = []
for block in re.split(r'\n\[\[package\]\]', lock_content):
    nm = re.search(r'name = "([^"]+)"', block)
    vm = re.search(r'version = "([^"]+)"', block)
    if nm and vm and nm.group(1) != "parquet-swift":
        rust_packages.append((nm.group(1), vm.group(1)))

# ── Parse Package.resolved ───────────────────────────────────────────────────
with open(pkg_resolved_path) as f:
    resolved = json.load(f)

swift_pins = resolved.get("pins", [])

# ── Helpers ──────────────────────────────────────────────────────────────────
def read_crate(name, version):
    d = os.path.join(REG, f"{name}-{version}")
    ct = os.path.join(d, "Cargo.toml")
    if not os.path.exists(ct):
        return None
    with open(ct) as f:
        toml = f.read()
    lm = re.search(r'^license\s*=\s*"([^"]+)"', toml, re.MULTILINE)
    rm = re.search(r'^repository\s*=\s*"([^"]+)"', toml, re.MULTILINE)
    files = {}
    for fn in ["LICENSE", "LICENSE.txt", "LICENSE.md", "LICENSE-APACHE", "LICENSE-MIT",
               "LICENSE-Apache-2.0", "LICENCE", "COPYING", "UNLICENSE"]:
        p = os.path.join(d, fn)
        if os.path.exists(p):
            with open(p) as f:
                files[fn] = f.read()
    return {
        "name": name, "version": version,
        "spdx": lm.group(1) if lm else "UNKNOWN",
        "repo": rm.group(1) if rm else "",
        "files": files,
    }

def chosen_license(spdx):
    for x in ["Apache-2.0", "MPL-2.0", "MIT", "BSD-3-Clause", "BSD-2-Clause", "CC0-1.0"]:
        if x in spdx:
            return x
    if "Unlicense" in spdx:
        return "MIT"
    return spdx

def best_license_text(crate, lic):
    files = crate["files"]
    if lic == "Apache-2.0":
        for k in ["LICENSE-APACHE", "LICENSE", "LICENSE.txt"]:
            if k in files and "Apache" in files[k]:
                return files[k].strip()
    elif lic == "MIT":
        for k in ["LICENSE-MIT", "LICENSE", "LICENSE.txt"]:
            if k in files and ("Permission is hereby" in files[k] or "MIT" in files[k][:200]):
                return files[k].strip()
        for v in files.values():
            if "Permission is hereby" in v:
                return v.strip()
    elif lic == "MPL-2.0":
        for v in files.values():
            if "Mozilla" in v:
                return v.strip()
    elif lic in ("BSD-3-Clause", "BSD-2-Clause"):
        for v in files.values():
            if "Redistributions" in v:
                return v.strip()
    for v in files.values():
        return v.strip()
    return None

def extract_copyright(text):
    if not text:
        return None
    for line in text.split("\n"):
        s = line.strip()
        if re.match(r"(copyright|\(c\)|©)", s, re.I) and len(s) > 10:
            return s
    return None

# ── Load Rust crate data ─────────────────────────────────────────────────────
crates = [c for n, v in rust_packages if (c := read_crate(n, v))]
for c in crates:
    c["chosen"] = chosen_license(c["spdx"])
    c["text"] = best_license_text(c, c["chosen"])

# ── Swift dep license data ───────────────────────────────────────────────────
# Well-known copyright lines per package identity
SWIFT_COPYRIGHTS = {
    "swift-syntax":        "Copyright (c) 2014 - 2024 Apple Inc. and the Swift project authors",
    "swift-docc-plugin":   "Copyright (c) 2022 Apple Inc. and the Swift project authors",
    "swift-docc-symbolkit":"Copyright (c) 2021 Apple Inc. and the Swift project authors",
}

swift_deps = []
swift_apache_text = None

for pin in swift_pins:
    identity = pin["identity"]
    version  = pin["state"].get("version", pin["state"].get("revision", "unknown"))
    location = pin["location"]
    copyright = SWIFT_COPYRIGHTS.get(identity, f"Copyright (c) Apple Inc. and the Swift project authors")

    # Try to read license text from checkout
    checkout_dir = os.path.join(checkouts_dir, identity)
    lic_text = None
    if os.path.isdir(checkout_dir):
        for fn in ["LICENSE.txt", "LICENSE", "LICENSE.md"]:
            p = os.path.join(checkout_dir, fn)
            if os.path.exists(p):
                with open(p) as f:
                    lic_text = f.read().strip()
                break

    if lic_text and swift_apache_text is None:
        swift_apache_text = lic_text

    swift_deps.append({
        "name": identity,
        "version": version,
        "location": location,
        "copyright": copyright,
        "text": lic_text,
    })

# Fallback: derive Apache-2.0 text from a Rust crate that has it
if swift_apache_text is None:
    swift_apache_text = next(
        (c["text"] for c in crates
         if c["chosen"] == "Apache-2.0" and c["text"] and "Apache License" in c["text"]),
        "[Apache License, Version 2.0 — see https://www.apache.org/licenses/LICENSE-2.0]"
    )

SWIFT_RUNTIME_EXCEPTION = """\
ADDITIONAL LICENSE INFORMATION — Swift Runtime Library Exception

As an exception, if you use this Software to compile your source code and
portions of this Software are embedded into the binary product as a result, you
may redistribute such product without providing attribution as would otherwise
be required by Sections 4(a), 4(b) and 4(d) of the License."""

MPL2_TEXT = """\
Mozilla Public License Version 2.0
==================================

