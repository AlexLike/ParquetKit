#!/usr/bin/env python3
"""
Patches Package.swift to use a local ParquetKitRustDriver.xcframework instead of
a downloaded release binary. Committing this change signals the release
pipeline to rebuild the xcframework on the next release.
"""
import re, sys

PATH = "Package.swift"
text = open(PATH).read()

pattern = (
    r'\.binaryTarget\(\s*\n\s*name:\s*"ParquetKitRustDriver",\s*\n\s*'
    r'url:\s*"[^"]+",\s*\n\s*checksum:\s*"[^"]+"\s*\n\s*\)'
)
replacement = (
    '.binaryTarget(\n'
    '      name: "ParquetKitRustDriver",\n'
    '      path: "ParquetKitRustDriver.xcframework"\n'
    '    )'
)

new_text, n = re.subn(pattern, replacement, text)
if n == 0:
    print("Package.swift is already using path: form — nothing to do.")
    sys.exit(0)
if n != 1:
    print(f"ERROR: Expected 1 match, got {n}.", file=sys.stderr)
    sys.exit(1)

open(PATH, "w").write(new_text)
print("Package.swift patched to use local ParquetKitRustDriver.xcframework.")
print("Commit this change to trigger a full xcframework rebuild on the next release.")
